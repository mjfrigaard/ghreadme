install.packages("gert")
usethis::use_package("gert")
usethis::use_package("cli")
usethis::use_package("glue")
usethis::use_r("who_am_i")
who_am_i <- function(name, likes, learn, work, collab, connect = TRUE){
cli::cli_text("👋 Hi, my name is {name}.")
Sys.sleep(time = 1.5)
cli::cli_text("👀 I like {likes}")
Sys.sleep(time = 1.5)
cli::cli_text("🌱 I'm learning about {learn}")
Sys.sleep(time = 1.5)
cli::cli_text("📦 I'm currently working on {work}")
Sys.sleep(time = 1.5)
cli::cli_text("💞 I'd love to collaborate on {collab}")
Sys.sleep(time = 1.5)
if (connect) {
cli::cli_text("📫 Want to connect? Use the badges below...")
}
who_am_i <- function(name, likes, learn, work, collab, connect = TRUE){
cli::cli_text(
glue::glue("👋 Hi, my name is {name}.")
)
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("👀 I like {likes}"))
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("🌱 I'm learning about {learn}"))
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("📦 I'm currently working on {work}"))
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("💞 I'd love to collaborate on {collab}"))
Sys.sleep(time = 1.5)
if (connect) {
cli::cli_text("📫 Want to connect? Use the badges below...")
}
who_am_i <- function(name, likes, learn, work, collab, connect = TRUE){
cli::cli_text(
glue::glue("👋 Hi, my name is {name}.")
)
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("👀 I like {likes}"))
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("🌱 I'm learning about {learn}"))
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("📦 I'm currently working on {work}"))
Sys.sleep(time = 1.5)
cli::cli_text(glue::glue("💞 I'd love to collaborate on {collab}"))
Sys.sleep(time = 1.5)
if (connect) {
cli::cli_text("📫 Want to connect? Use the badges below...")
}
who_am_i(name = "Martin",
likes = "#rstats and data visualization.",
learn = "shiny app development, JavaScript, and Bayesian statistics.",
work = "R package development tools.",
collab = "#rstats packages for data science.")
devtools::load_all(".")
devtools:::document()
library(ghreadme)
devtools::load_all(".")
